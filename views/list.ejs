<% layout('layouts/boilerplate') -%>

<div class="container" style="max-width: 750px; margin: 60px auto; font-family: 'Plus Jakarta Sans', sans-serif;">

    <h3 class="mb-4 fw-semibold">Listing Details</h3>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

        <!-- Image -->
        <img 
            src="<%= list.image %>" 
            class="card-img-top" 
            style="height: 300px; object-fit: cover;" 
            alt="Listing Image">

        <!-- Card Body -->
        <div class="card-body">

            <h5 class="card-title fw-semibold"><%= list.title %></h5>

            <p class="card-text text-muted mb-2">
                <%= list.description %>
            </p>

            <h6 class="fw-bold mb-3">
                ₹ <%= list.price.toLocaleString('en-IN') %>
            </h6>

            <p class="mb-1"><%= list.location %></p>
            <p class="text-muted"><%= list.country %></p>

            <!-- Buttons -->
            <div class="d-flex gap-3 mt-3">
                <a href="/editlist/<%= list._id %>" class="btn btn-danger px-4">
                    Edit
                </a>

                <a href="/deletelist/<%= list._id %>" class="btn btn-dark px-4">
                    Delete
                </a>
            </div>

        </div>
    </div>
</div>
